<view class="page">

  <!-- Tab bar -->
  <view class="tab-bar">
    <view class="tab {{activeTab==='advisor'?'active':''}}" data-tab="advisor" bindtap="switchTab">建议</view>
    <view class="tab {{activeTab==='history'?'active':''}}" data-tab="history" bindtap="switchTab">记录</view>
    <view class="tab {{activeTab==='summary'?'active':''}}" data-tab="summary" bindtap="switchTab">摘要</view>
  </view>

  <!-- ── 建议 Tab ── -->
  <scroll-view wx:if="{{activeTab==='advisor'}}" scroll-y class="tab-content">

    <!-- 输入区 -->
    <view class="input-card">

      <!-- 截图按钮 -->
      <view class="btn-screenshot {{extracting?'disabled':''}}" bindtap="pickScreenshot">
        <text wx:if="{{!extracting}}">+ 上传截图识别</text>
        <text wx:else>识别中...</text>
      </view>

      <!-- OCR 对话预览 -->
      <view wx:if="{{ocrMessages.length}}" class="ocr-preview">
        <view class="ocr-preview-head">
          <text class="ocr-label">识别结果</text>
          <view class="ocr-clear" bindtap="clearExtract">清除</view>
        </view>
        <view class="ocr-feed">
          <view class="ocr-msg {{item.role==='girl'?'ocr-girl':'ocr-me'}}"
                wx:for="{{ocrMessages}}" wx:key="index">
            <view class="ocr-bubble">{{item.content}}</view>
          </view>
        </view>
        <view class="ocr-save-row">
          <view class="btn-save-ocr" bindtap="saveOcrToHistory">存入记录</view>
        </view>
      </view>

      <!-- 分隔 -->
      <view class="divider"><text>或手动输入</text></view>

      <textarea
        class="msg-input"
        placeholder="粘贴她刚发的消息..."
        bindinput="onInput"
        maxlength="2000"
        auto-height
      />
      <view class="input-footer">
        <text class="char-count">{{girlMsgLen}}</text>
        <view class="btn-analyze {{analyzing?'btn-disabled':''}}" bindtap="doAnalyze">
          <text wx:if="{{!analyzing}}">分析回复</text>
          <text wx:else>分析中...</text>
        </view>
      </view>
    </view>

    <!-- 加载 -->
    <view wx:if="{{analyzing}}" class="loading-box">
      <view class="spinner"></view>
      <text>分析中...</text>
    </view>

    <!-- 结果 -->
    <block wx:if="{{result && !analyzing}}">

      <!-- 策略 -->
      <view class="result-card">
        <view class="rc-label">策略</view>
        <view class="rc-text">{{result.overall_strategy}}</view>
        <view class="rc-sub" wx:if="{{result.next_direction}}">→ {{result.next_direction}}</view>
      </view>

      <!-- 回复选项 -->
      <view class="reply-cards">
        <view class="reply-card" wx:for="{{result.styles}}" wx:key="style_name">
          <view class="reply-card-head">
            <text class="reply-style-name">{{item.style_name}}</text>
            <text class="reply-style-desc">{{item.style_desc}}</text>
          </view>
          <view class="reply-list">
            <view class="reply-item" wx:for="{{item.replies}}" wx:key="*this" wx:for-item="r">
              <text class="reply-text">{{r}}</text>
              <view class="reply-btns">
                <view class="btn-copy" data-text="{{r}}" bindtap="copyReply">复制</view>
                <view class="btn-sent" data-text="{{r}}" bindtap="markSent">已发送</view>
              </view>
            </view>
          </view>
          <view class="reply-reason" wx:if="{{item.reasoning}}">{{item.reasoning}}</view>
        </view>
      </view>

      <!-- 重新生成 -->
      <view class="regen-card">
        <textarea
          class="fb-input"
          placeholder="不满意？说说哪里不好..."
          value="{{feedback}}"
          bindinput="onFbInput"
          maxlength="200"
          auto-height
        />
        <view class="btn-regen {{reging?'btn-disabled':''}}" bindtap="doFeedback">
          <text wx:if="{{!reging}}">重新生成</text>
          <text wx:else>生成中...</text>
        </view>
      </view>

    </block>
  </scroll-view>

  <!-- ── 记录 Tab ── -->
  <scroll-view wx:if="{{activeTab==='history'}}" scroll-y class="tab-content">
    <view class="tab-head">
      <text class="tab-head-title">对话记录</text>
      <view class="btn-sm" bindtap="refreshHistory">刷新</view>
    </view>
    <view wx:if="{{messages.length===0}}" class="empty-hint">
      <text>暂无记录\n点「已发送」或「存入记录」可记录到此</text>
    </view>
    <view class="chat-feed">
      <view class="msg-group {{item.role==='girl'?'msg-girl':'msg-me'}}"
            wx:for="{{messages}}" wx:key="id">
        <view class="msg-av">{{item.role==='girl'?convInitial:'我'}}</view>
        <view class="msg-wrap">
          <view class="msg-bubble {{item.role==='girl'?'bubble-girl':'bubble-me'}}">{{item.content}}</view>
          <view class="msg-time">{{item.timeStr}}</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- ── 摘要 Tab ── -->
  <scroll-view wx:if="{{activeTab==='summary'}}" scroll-y class="tab-content">
    <view class="tab-head">
      <text class="tab-head-title">关系摘要</text>
      <view class="btn-sm btn-sm-white" bindtap="doSummarize">更新</view>
    </view>
    <view wx:if="{{!summary}}" class="empty-hint">
      <text>至少 4 条对话后点「更新」生成摘要</text>
    </view>
    <block wx:if="{{summary}}">
      <view class="sum-card">
        <view class="sum-label">关系阶段</view>
        <view class="sum-row">
          <text class="sum-stage">{{summary.relationship_stage||'未知'}}</text>
          <text class="sum-momentum">{{momentumIcon}} {{summary.momentum||'平稳'}}</text>
        </view>
        <view class="progress-track">
          <view class="progress-fill" style="width:{{progressPct}}%"></view>
        </view>
      </view>
      <view class="sum-card" wx:if="{{summary.her_traits&&summary.her_traits.length}}">
        <view class="sum-label">她的特点</view>
        <view class="chip-row">
          <view class="chip" wx:for="{{summary.her_traits}}" wx:key="*this">{{item}}</view>
        </view>
      </view>
      <view class="sum-card" wx:if="{{summary.her_interests&&summary.her_interests.length}}">
        <view class="sum-label">兴趣爱好</view>
        <view class="chip-row">
          <view class="chip" wx:for="{{summary.her_interests}}" wx:key="*this">{{item}}</view>
        </view>
      </view>
      <view class="sum-card" wx:if="{{summary.summary}}">
        <view class="sum-label">AI 总结</view>
        <text class="sum-text">{{summary.summary}}</text>
      </view>
      <view class="sum-card" wx:if="{{summary.recommended_style}}">
        <view class="sum-label">建议风格</view>
        <text class="sum-text">{{summary.recommended_style}}</text>
      </view>
    </block>
  </scroll-view>

</view>
