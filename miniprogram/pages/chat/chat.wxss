/* ── 全局 ── */
page { background: #111; color: #f0f0f0; }
.page { display: flex; flex-direction: column; height: 100vh; background: #111; }

/* ── Tab bar ── */
.tab-bar {
  display: flex;
  background: #111;
  border-bottom: 1rpx solid #2a2a2a;
  flex-shrink: 0;
}
.tab {
  flex: 1;
  padding: 22rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #555;
  border-bottom: 3rpx solid transparent;
  letter-spacing: 2rpx;
}
.tab.active { color: #f0f0f0; border-bottom-color: #f0f0f0; }

/* ── Tab content ── */
.tab-content { flex: 1; overflow: hidden; padding: 24rpx 24rpx 80rpx; }

/* ── Tab head ── */
.tab-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.tab-head-title { font-size: 22rpx; color: #555; letter-spacing: 2rpx; }
.btn-sm {
  padding: 8rpx 22rpx;
  border: 1rpx solid #2a2a2a;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #555;
}
.btn-sm-white { border-color: #555; color: #f0f0f0; }

/* ── Input card ── */
.input-card {
  background: #1a1a1a;
  border: 1rpx solid #2a2a2a;
  border-radius: 16rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
}
.btn-screenshot {
  display: block;
  text-align: center;
  border: 1rpx dashed #3a3a3a;
  border-radius: 12rpx;
  padding: 18rpx;
  font-size: 26rpx;
  color: #aaa;
  margin-bottom: 16rpx;
}
.btn-screenshot.disabled { opacity: .4; }

/* ── OCR 预览 ── */
.ocr-preview {
  background: #141414;
  border: 1rpx solid #2a2a2a;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}
.ocr-preview-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.ocr-label { font-size: 20rpx; color: #555; letter-spacing: 2rpx; }
.ocr-clear { font-size: 22rpx; color: #444; padding: 4rpx 10rpx; }
.ocr-feed { display: flex; flex-direction: column; gap: 10rpx; }
.ocr-msg { display: flex; }
.ocr-girl { justify-content: flex-start; }
.ocr-me   { justify-content: flex-end; }
.ocr-bubble {
  max-width: 76%;
  padding: 10rpx 16rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #e0e0e0;
}
.ocr-girl .ocr-bubble { background: #252525; border-radius: 4rpx 14rpx 14rpx 14rpx; }
.ocr-me   .ocr-bubble { background: transparent; border: 1rpx solid #333; border-radius: 14rpx 4rpx 14rpx 14rpx; }
.ocr-save-row { margin-top: 12rpx; display: flex; justify-content: flex-end; }
.btn-save-ocr {
  padding: 8rpx 20rpx;
  border: 1rpx solid #3a3a3a;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #888;
}

/* ── 分隔线 ── */
.divider {
  text-align: center;
  font-size: 20rpx;
  color: #333;
  margin: 14rpx 0;
}

/* ── 手动输入 ── */
.msg-input {
  width: 100%;
  background: transparent;
  color: #e0e0e0;
  font-size: 28rpx;
  line-height: 1.6;
  min-height: 90rpx;
}
.input-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 14rpx; padding-top: 14rpx; border-top: 1rpx solid #2a2a2a; }
.char-count { font-size: 22rpx; color: #444; }
.btn-analyze {
  background: #f0f0f0;
  color: #111;
  padding: 14rpx 30rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
}
.btn-disabled { opacity: .4; }

/* ── 加载 ── */
.loading-box { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 60rpx; color: #444; font-size: 24rpx; }
.spinner { width: 56rpx; height: 56rpx; border: 3rpx solid #2a2a2a; border-top-color: #f0f0f0; border-radius: 50%; animation: spin .8s linear infinite; }
@keyframes spin { from{transform:rotate(0)} to{transform:rotate(360deg)} }

/* ── 策略卡 ── */
.result-card {
  background: #1a1a1a;
  border: 1rpx solid #2a2a2a;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}
.rc-label { font-size: 18rpx; color: #444; letter-spacing: 3rpx; margin-bottom: 10rpx; }
.rc-text  { font-size: 27rpx; line-height: 1.65; color: #e0e0e0; margin-bottom: 6rpx; }
.rc-sub   { font-size: 24rpx; color: #666; border-top: 1rpx solid #2a2a2a; padding-top: 10rpx; margin-top: 6rpx; }

/* ── 回复卡 ── */
.reply-cards { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 16rpx; }
.reply-card {
  background: #1a1a1a;
  border: 1rpx solid #2a2a2a;
  border-radius: 14rpx;
  padding: 18rpx;
}
.reply-card-head { margin-bottom: 14rpx; }
.reply-style-name { font-size: 26rpx; font-weight: 600; color: #f0f0f0; display: block; margin-bottom: 4rpx; }
.reply-style-desc { font-size: 22rpx; color: #555; display: block; }
.reply-list { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 12rpx; }
.reply-item { background: #111; border-radius: 10rpx; padding: 14rpx; }
.reply-text { font-size: 27rpx; line-height: 1.6; color: #e0e0e0; display: block; margin-bottom: 10rpx; }
.reply-btns { display: flex; gap: 10rpx; }
.btn-copy {
  padding: 7rpx 18rpx;
  border: 1rpx solid #2a2a2a;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #777;
}
.btn-sent {
  padding: 7rpx 18rpx;
  border: 1rpx solid #3a3a3a;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #aaa;
}
.reply-reason { font-size: 22rpx; color: #444; line-height: 1.55; padding-top: 12rpx; border-top: 1rpx solid #222; }

/* ── 重新生成 ── */
.regen-card {
  background: #1a1a1a;
  border: 1rpx solid #2a2a2a;
  border-radius: 14rpx;
  padding: 18rpx;
  margin-bottom: 20rpx;
}
.fb-input {
  width: 100%;
  background: #111;
  border: 1rpx solid #2a2a2a;
  border-radius: 10rpx;
  padding: 14rpx;
  color: #e0e0e0;
  font-size: 26rpx;
  line-height: 1.6;
  min-height: 70rpx;
  margin-bottom: 12rpx;
}
.btn-regen {
  text-align: center;
  border: 1rpx solid #3a3a3a;
  color: #aaa;
  padding: 14rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
}

/* ── 记录 Tab ── */
.empty-hint { text-align: center; padding: 60rpx 30rpx; color: #444; font-size: 26rpx; line-height: 2; }
.chat-feed { display: flex; flex-direction: column; gap: 20rpx; }
.msg-group { display: flex; gap: 12rpx; align-items: flex-end; }
.msg-girl { flex-direction: row; }
.msg-me   { flex-direction: row-reverse; }
.msg-av {
  width: 52rpx; height: 52rpx;
  border-radius: 50%;
  background: #2a2a2a;
  color: #888;
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; font-weight: 600;
  flex-shrink: 0;
}
.msg-wrap { display: flex; flex-direction: column; max-width: 72%; }
.msg-me .msg-wrap { align-items: flex-end; }
.msg-bubble {
  padding: 14rpx 20rpx;
  border-radius: 18rpx;
  font-size: 27rpx;
  line-height: 1.6;
  color: #e8e8e8;
}
.bubble-girl { background: #252525; border-radius: 4rpx 18rpx 18rpx 18rpx; }
.bubble-me   { background: transparent; border: 1rpx solid #333; border-radius: 18rpx 4rpx 18rpx 18rpx; }
.msg-time { font-size: 20rpx; color: #3a3a3a; margin-top: 5rpx; padding: 0 4rpx; }

/* ── 摘要 Tab ── */
.sum-card { background: #1a1a1a; border: 1rpx solid #2a2a2a; border-radius: 14rpx; padding: 20rpx; margin-bottom: 14rpx; }
.sum-label { font-size: 18rpx; color: #444; letter-spacing: 3rpx; margin-bottom: 12rpx; }
.sum-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 12rpx; }
.sum-stage { font-size: 28rpx; font-weight: 600; color: #f0f0f0; }
.sum-momentum { font-size: 26rpx; color: #888; }
.progress-track { height: 6rpx; background: #2a2a2a; border-radius: 3rpx; overflow: hidden; }
.progress-fill  { height: 100%; background: #f0f0f0; border-radius: 3rpx; }
.chip-row { display: flex; flex-wrap: wrap; gap: 10rpx; }
.chip { padding: 6rpx 18rpx; border: 1rpx solid #2a2a2a; border-radius: 20rpx; font-size: 22rpx; color: #888; }
.sum-text { font-size: 26rpx; line-height: 1.7; color: #c0c0c0; }
