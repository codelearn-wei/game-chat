page { background: #080810; color: #e8eaf2; }
.page { display: flex; flex-direction: column; height: 100vh; background: #080810; }

/* Tab bar */
.tab-bar {
  display: flex;
  border-bottom: 1rpx solid #252545;
  background: #0d0d1a;
  flex-shrink: 0;
}
.tab {
  flex: 1;
  padding: 20rpx 4rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8b8fa8;
  border-bottom: 4rpx solid transparent;
  font-weight: 500;
}
.tab.active { color: #7c3aed; border-bottom-color: #7c3aed; }

/* Tab content */
.tab-content { flex: 1; overflow: hidden; padding: 24rpx 24rpx 80rpx; }

/* Input card */
.input-card {
  background: #141428;
  border: 1rpx solid #252545;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.input-label { font-size: 22rpx; color: #8b8fa8; text-transform: uppercase; letter-spacing: 2rpx; margin-bottom: 14rpx; }
.msg-input {
  width: 100%;
  background: transparent;
  color: #e8eaf2;
  font-size: 28rpx;
  line-height: 1.6;
  min-height: 100rpx;
}
.input-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #252545; }
.char-count { font-size: 22rpx; color: #555878; }
.btn-analyze {
  background: #7c3aed;
  color: #fff;
  padding: 14rpx 30rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
}
.btn-analyze.disabled { opacity: .5; }

/* ── Screenshot OCR ── */
.screenshot-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}
.btn-screenshot {
  background: rgba(6,182,212,.12);
  border: 1rpx solid rgba(6,182,212,.45);
  color: #06b6d4;
  padding: 12rpx 22rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.btn-screenshot.disabled { opacity: .5; }
.screenshot-tip { font-size: 21rpx; color: #555878; }

.extract-preview {
  background: rgba(6,182,212,.06);
  border: 1rpx solid rgba(6,182,212,.25);
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 14rpx;
}
.ep-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.ep-label { font-size: 22rpx; color: #06b6d4; font-weight: 600; }
.ep-clear { font-size: 22rpx; color: #555878; padding: 4rpx 10rpx; }
.ep-text {
  font-size: 26rpx;
  color: #c8cae0;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-all;
}

.divider-or {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #3a3d5a;
  margin: 8rpx 0 12rpx;
}

/* Loading */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 60rpx;
  color: #8b8fa8;
  font-size: 26rpx;
}
.spinner {
  width: 60rpx; height: 60rpx;
  border: 4rpx solid #252545;
  border-top-color: #7c3aed;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { from{transform:rotate(0)} to{transform:rotate(360deg)} }

/* Strategy banner */
.strategy-banner {
  background: linear-gradient(135deg, rgba(124,58,237,.12), rgba(6,182,212,.06));
  border: 1rpx solid rgba(124,58,237,.3);
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.strategy-lbl { font-size: 20rpx; font-weight: 700; color: #7c3aed; letter-spacing: 2rpx; margin-bottom: 10rpx; }
.strategy-text { font-size: 26rpx; line-height: 1.7; color: #e8eaf2; margin-bottom: 8rpx; }
.next-dir { font-size: 24rpx; color: #06b6d4; border-top: 1rpx solid rgba(6,182,212,.2); padding-top: 10rpx; }

/* Style cards */
.style-list { display: flex; flex-direction: column; gap: 18rpx; margin-bottom: 20rpx; }
.style-card {
  background: #141428;
  border: 1rpx solid #252545;
  border-radius: 18rpx;
  padding: 22rpx;
  border-top-width: 4rpx;
}
.style-0 { border-top-color: #06b6d4; }
.style-1 { border-top-color: #f97316; }
.style-2 { border-top-color: #eab308; }
.style-3 { border-top-color: #ec4899; }
.style-4 { border-top-color: #8b5cf6; }
.sc-head { display: flex; gap: 16rpx; margin-bottom: 16rpx; align-items: flex-start; }
.sc-icon { font-size: 40rpx; flex-shrink: 0; }
.sc-meta { flex: 1; }
.sc-name { font-size: 28rpx; font-weight: 700; display: block; margin-bottom: 4rpx; }
.style-0 .sc-name { color: #06b6d4; }
.style-1 .sc-name { color: #f97316; }
.style-2 .sc-name { color: #eab308; }
.style-3 .sc-name { color: #ec4899; }
.style-4 .sc-name { color: #8b5cf6; }
.sc-desc { font-size: 22rpx; color: #8b8fa8; display: block; }
.skill-tag {
  display: inline-block;
  margin-top: 8rpx;
  padding: 4rpx 14rpx;
  background: rgba(245,158,11,.12);
  border: 1rpx solid rgba(245,158,11,.3);
  color: #f59e0b;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 600;
}
.reply-list { display: flex; flex-direction: column; gap: 14rpx; margin-bottom: 14rpx; }
.reply-item { background: #1a1a35; border-radius: 12rpx; padding: 16rpx; }
.reply-text { font-size: 27rpx; line-height: 1.6; color: #e8eaf2; display: block; margin-bottom: 12rpx; }
.reply-btns { display: flex; gap: 12rpx; }
.btn-copy {
  padding: 8rpx 20rpx;
  border: 1rpx solid #252545;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #8b8fa8;
}
.btn-sent {
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(16,185,129,.4);
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #10b981;
}
.sc-reasoning {
  font-size: 23rpx;
  color: #8b8fa8;
  line-height: 1.6;
  padding-top: 14rpx;
  border-top: 1rpx solid #252545;
}

/* Feedback */
.feedback-card {
  background: #141428;
  border: 1rpx solid #252545;
  border-radius: 18rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
}
.fb-label { font-size: 22rpx; font-weight: 600; color: #f59e0b; margin-bottom: 14rpx; }
.fb-input {
  width: 100%;
  background: #1a1a35;
  border: 1rpx solid #252545;
  border-radius: 12rpx;
  padding: 16rpx;
  color: #e8eaf2;
  font-size: 26rpx;
  line-height: 1.6;
  min-height: 80rpx;
  margin-bottom: 14rpx;
}
.btn-regen {
  background: rgba(245,158,11,.15);
  border: 1rpx solid rgba(245,158,11,.4);
  color: #f59e0b;
  padding: 14rpx 30rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}
.btn-regen.disabled { opacity: .5; }

/* History */
.history-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.section-label { font-size: 22rpx; font-weight: 700; color: #8b8fa8; text-transform: uppercase; letter-spacing: 2rpx; }
.btn-sm {
  padding: 8rpx 20rpx;
  border: 1rpx solid #252545;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #8b8fa8;
}
.btn-sm.primary { border-color: #7c3aed; color: #7c3aed; }
.empty-hint { text-align: center; padding: 60rpx 30rpx; color: #555878; font-size: 26rpx; line-height: 1.8; }

/* Chat bubbles */
.chat-feed { display: flex; flex-direction: column; gap: 22rpx; }
.msg-group { display: flex; gap: 14rpx; align-items: flex-end; }
.msg-group.me { flex-direction: row-reverse; }
.msg-av {
  width: 56rpx; height: 56rpx;
  border-radius: 50rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700;
  flex-shrink: 0;
}
.girl .msg-av { background: rgba(124,58,237,.25); color: #9d5df0; }
.me .msg-av { background: rgba(16,185,129,.2); color: #10b981; }
.msg-wrap { display: flex; flex-direction: column; max-width: 72%; }
.me .msg-wrap { align-items: flex-end; }
.msg-bubble {
  padding: 16rpx 22rpx;
  border-radius: 20rpx;
  font-size: 27rpx;
  line-height: 1.6;
}
.bubble-girl { background: #1a1a35; border-radius: 6rpx 20rpx 20rpx 20rpx; color: #e8eaf2; }
.bubble-me { background: rgba(124,58,237,.18); border: 1rpx solid rgba(124,58,237,.3); border-radius: 20rpx 6rpx 20rpx 20rpx; color: #e8eaf2; }
.msg-time { font-size: 20rpx; color: #555878; margin-top: 6rpx; padding: 0 4rpx; }

/* Summary */
.sum-card { background: #141428; border: 1rpx solid #252545; border-radius: 16rpx; padding: 22rpx; margin-bottom: 16rpx; }
.sum-title { font-size: 20rpx; font-weight: 700; color: #8b8fa8; text-transform: uppercase; letter-spacing: 2rpx; margin-bottom: 14rpx; }
.stage-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 14rpx; }
.stage-badge { padding: 6rpx 18rpx; background: rgba(6,182,212,.12); border: 1rpx solid rgba(6,182,212,.3); color: #06b6d4; border-radius: 12rpx; font-size: 26rpx; font-weight: 600; }
.momentum { font-size: 30rpx; font-weight: 700; }
.progress-track { height: 12rpx; background: #252545; border-radius: 6rpx; overflow: hidden; margin-bottom: 8rpx; }
.progress-fill { height: 100%; border-radius: 6rpx; }
.progress-labels { display: flex; justify-content: space-between; font-size: 20rpx; color: #555878; }
.chip-group { display: flex; flex-wrap: wrap; gap: 10rpx; }
.chip { padding: 6rpx 18rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 500; }
.chip-purple { background: rgba(124,58,237,.15); border: 1rpx solid rgba(124,58,237,.3); color: #9d5df0; }
.chip-cyan { background: rgba(6,182,212,.12); border: 1rpx solid rgba(6,182,212,.25); color: #06b6d4; }
.chip-gold { background: rgba(245,158,11,.12); border: 1rpx solid rgba(245,158,11,.3); color: #f59e0b; }
.sum-text { font-size: 26rpx; line-height: 1.7; color: #e8eaf2; }

.empty-chat {
  text-align: center;
  color: #475569;
  font-size: 26rpx;
  padding: 80rpx 40rpx;
}

.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 20rpx;
  gap: 12rpx;
}
.from-a { flex-direction: row-reverse; }

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.avatar-a { background: #7c3aed; color: white; }
.avatar-b { background: #0f766e; color: white; }

.bubble {
  max-width: 65%;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}
.bubble-a {
  background: #4f46e5;
  color: white;
  border-bottom-right-radius: 6rpx;
}
.bubble-b {
  background: #1e293b;
  color: #e2e8f0;
  border-bottom-left-radius: 6rpx;
}

/* 正在思考动画 */
.thinking {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 24rpx;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #94a3b8;
  animation: blink 1.2s infinite;
}
.dot:nth-child(2) { animation-delay: .2s; }
.dot:nth-child(3) { animation-delay: .4s; }
@keyframes blink {
  0%, 80%, 100% { opacity: .2; }
  40% { opacity: 1; }
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #1a1a2e;
  border-top: 2rpx solid #2a2a4a;
  flex-shrink: 0;
}
.persona-tag {
  background: #1e1030;
  color: #7c3aed;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}
.text-input {
  flex: 1;
  background: #0f0f1a;
  border: 2rpx solid #2a2a4a;
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  color: #e2e8f0;
  font-size: 28rpx;
  min-height: 72rpx;
}
.send-btn {
  background: #7c3aed;
  color: white;
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 28rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}
/* ── OCR 对话气泡展示 ── */
.parsed-conv {
  background: #0f0f22;
  border: 1rpx solid #252545;
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 16rpx;
}
.pc-hdr { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx; }
.pc-lbl { font-size: 22rpx; font-weight: 700; color: #7c3aed; }
.pc-clear { font-size: 22rpx; color: #555878; padding: 4rpx 12rpx; }
.pc-bubbles { display: flex; flex-direction: column; gap: 10rpx; }
.pc-row { display: flex; }
.pc-row-me { justify-content: flex-end; }
.pc-row-girl { justify-content: flex-start; }
.pc-bbl { max-width: 75%; padding: 10rpx 16rpx; border-radius: 16rpx; font-size: 25rpx; line-height: 1.55; word-break: break-all; }
.pc-bbl-me { background: rgba(124,58,237,.18); border: 1rpx solid rgba(124,58,237,.3); color: #e8eaf2; border-radius: 16rpx 4rpx 16rpx 16rpx; }
.pc-bbl-girl { background: #1a1a35; color: #e8eaf2; border-radius: 4rpx 16rpx 16rpx 16rpx; }
.autofill-tip { margin-top: 14rpx; padding-top: 14rpx; border-top: 1rpx solid #252545; }
.autofill-lbl { font-size: 20rpx; color: #10b981; display: block; margin-bottom: 6rpx; }
.autofill-msg { font-size: 25rpx; color: #a78bfa; font-weight: 600; }
.mode-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.mode-opt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid #252545;
  background: #141428;
  gap: 4rpx;
}
.mode-on {
  border-color: rgba(124,58,237,.5);
  background: rgba(124,58,237,.1);
}
.mode-name { font-size: 26rpx; font-weight: 700; color: #8b8fa8; }
.mode-on .mode-name { color: #a78bfa; }
.mode-sub { font-size: 20rpx; color: #555878; }
.mode-on .mode-sub { color: #9d5df0; }

/* ── Game 技能点面板 ── */
.skill-panel {
  background: #0f0f22;
  border: 1rpx solid #252545;
  border-radius: 18rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 20rpx;
}
.skill-panel-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.skill-panel-title { font-size: 26rpx; font-weight: 700; color: #f59e0b; }
.skill-panel-tip { font-size: 20rpx; color: #555878; }
.skill-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.skill-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 18rpx;
  background: rgba(245,158,11,.08);
  border: 1rpx solid rgba(245,158,11,.25);
  border-radius: 14rpx;
  min-width: 120rpx;
}
.skill-btn-disabled { opacity: .5; }
.skill-btn-icon { font-size: 32rpx; }
.skill-btn-name { font-size: 22rpx; color: #f59e0b; font-weight: 600; }

/* ── 潜台词卡片 ── */
.subtext-card {
  background: rgba(16,185,129,.06);
  border: 1rpx solid rgba(16,185,129,.25);
  border-left: 4rpx solid #10b981;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.subtext-lbl { font-size: 22rpx; font-weight: 700; color: #10b981; }
.subtext-text { font-size: 26rpx; color: #c8cae0; line-height: 1.65; }

/* ── 技能回复结果卡 ── */
.skill-res-card {
  background: #141428;
  border: 1rpx solid rgba(245,158,11,.3);
  border-top: 4rpx solid #f59e0b;
  border-radius: 18rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
}
.skill-res-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.skill-res-title { font-size: 26rpx; font-weight: 700; color: #f59e0b; }
.skill-res-close { font-size: 26rpx; color: #555878; padding: 4rpx 12rpx; }
.skill-res-why {
  font-size: 25rpx;
  color: #a78bfa;
  line-height: 1.65;
  margin-bottom: 8rpx;
}
.skill-dir {
  font-size: 23rpx;
  color: #06b6d4;
  margin-bottom: 16rpx;
}
.skill-res-reasoning {
  font-size: 23rpx;
  color: #8b8fa8;
  line-height: 1.7;
  padding-top: 14rpx;
  border-top: 1rpx solid #252545;
}
