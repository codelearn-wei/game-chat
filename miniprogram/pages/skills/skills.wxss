.cat-bar {
  white-space: nowrap;
  padding: 0 0 20rpx;
}
.cat-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #94a3b8;
  background: #1a1a2e;
  border: 2rpx solid #2a2a4a;
  margin-right: 12rpx;
}
.cat-tag.active { background: #1e1030; border-color: #7c3aed; color: #7c3aed; }

.skill-card { cursor: pointer; }
.sk-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8rpx; }
.sk-name { font-size: 30rpx; font-weight: 700; margin-right: 12rpx; }
.sk-cat { font-size: 20rpx; color: #7c3aed; background: #1e1030; padding: 4rpx 12rpx; border-radius: 20rpx; }
.sk-tone { font-size: 22rpx; color: #64748b; margin-bottom: 8rpx; }
.sk-desc { font-size: 26rpx; color: #94a3b8; line-height: 1.5; margin-bottom: 14rpx; }

.sk-examples { border-top: 2rpx solid #2a2a4a; padding-top: 14rpx; }
.example { margin-bottom: 10rpx; }
.ex-context, .ex-response { display: block; font-size: 22rpx; color: #64748b; line-height: 1.5; }
.ex-response { color: #94a3b8; font-style: italic; }

.sk-check { font-size: 22rpx; }

.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #1a1a2e;
  border-top: 2rpx solid #2a2a4a;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
.bottom-bar button { flex: 1; }
